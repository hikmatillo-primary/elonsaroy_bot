BOT_TOKEN=your_bot_token_here
# docker-compose ichida DATABASE_URL avtomatik to'ldiriladi; lokal ishlatishda o'zgartirilsin
DATABASE_URL=postgresql+asyncpg://elonsaroy:your_password@localhost:5432/elonsaroy
ADMIN_CHANNEL_ID=-1001234567890
MAIN_CHANNEL_ID=-1001234567891
# Vergul bilan ajratilgan yoki yakka qiymat: 123456789 yoki 123456789,987654321
ADMIN_USER_IDS=123456789,987654321

# docker-compose uchun (PostgreSQL container paroli)
POSTGRES_PASSWORD=your_strong_password_here

# Ixtiyoriy: pgAdmin profile bilan ishlatilganda
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=admin
